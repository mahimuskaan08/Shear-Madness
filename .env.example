# Copy this file to .env.local and fill in the real values.
# Real values are stored in the Vercel project (Production environment).
# Ask the project owner for credentials.

# WordPress site base URL (no trailing slash)
WP_BASE_URL=https://your-wordpress-site.com

# Gravity Forms Web API v1 credentials
# Found in: WP Admin → Forms → Settings → Web API
GF_FORM_ID=2
GF_PUBLIC_API_KEY=your_public_key_here
GF_PRIVATE_API_KEY=your_private_key_here
GF_IMPERSONATE_ACCOUNT=your_wp_username_here
